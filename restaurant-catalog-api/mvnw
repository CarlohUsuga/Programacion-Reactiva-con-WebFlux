# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.2.0
# ----------------------------------------------------------------------------

set -e

# OS specific support.
cygwin=false
darwin=false
mingw=false
case "$(uname)" in
  CYGWIN*) cygwin=true ;;
  DARWIN*) darwin=true ;;
  MINGW*)  mingw=true  ;;
esac

# Resolve the real path of this script
if $cygwin || $mingw; then
  [ -n "$JAVA_HOME" ] && JAVA_HOME=$(cygpath --unix "$JAVA_HOME")
  [ -n "$MAVEN_HOME" ] && MAVEN_HOME=$(cygpath --unix "$MAVEN_HOME")
fi

# Locate the script directory
APP_HOME=$(cd "$(dirname "$0")" && pwd)

# Read properties file
MAVEN_WRAPPER_PROPERTIES="$APP_HOME/.mvn/wrapper/maven-wrapper.properties"
if [ -f "$MAVEN_WRAPPER_PROPERTIES" ]; then
  DISTRIBUTION_URL=$(grep "^distributionUrl=" "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2-)
else
  echo "Cannot find $MAVEN_WRAPPER_PROPERTIES" >&2
  exit 1
fi

# Derive the maven distribution directory name from the URL
MAVEN_DIST_NAME=$(basename "$DISTRIBUTION_URL" .zip)
MAVEN_HOME="${MAVEN_USER_HOME:-$HOME/.m2/wrapper/dists}/$MAVEN_DIST_NAME"

# Download and unzip Maven if not already present
if [ ! -d "$MAVEN_HOME" ]; then
  echo "Downloading Maven from $DISTRIBUTION_URL ..."
  mkdir -p "$MAVEN_HOME"

  TMP_DOWNLOAD="$MAVEN_HOME/maven-download.zip"

  if command -v wget > /dev/null 2>&1; then
    wget -q -O "$TMP_DOWNLOAD" "$DISTRIBUTION_URL"
  elif command -v curl > /dev/null 2>&1; then
    curl -sL -o "$TMP_DOWNLOAD" "$DISTRIBUTION_URL"
  else
    echo "Neither wget nor curl is available. Cannot download Maven." >&2
    exit 1
  fi

  echo "Unzipping Maven ..."
  unzip -q "$TMP_DOWNLOAD" -d "$MAVEN_HOME"
  rm -f "$TMP_DOWNLOAD"

  echo "Maven $MAVEN_DIST_NAME installed."
fi

# Find the maven executable inside the extracted directory
MAVEN_BIN=$(find "$MAVEN_HOME" -name "mvn" -type f | head -1)
if [ -z "$MAVEN_BIN" ]; then
  echo "Could not find mvn executable inside $MAVEN_HOME" >&2
  exit 1
fi

chmod +x "$MAVEN_BIN"

exec "$MAVEN_BIN" "$@"
